---
import { works } from "@/data/works"
import { Image } from "astro:assets"
---

<div
  id="timeline-wrapper"
  class="relative w-full bg-background text-foreground"
  style="min-height: 300vh;"
>
  <div
    class="sticky top-0 flex h-screen w-full flex-col justify-center overflow-hidden"
  >
    <!-- Timeline Container -->
    <div
      id="timeline-container"
      class="z-10 flex h-full w-max items-center gap-28 px-[50vw] will-change-transform"
    >
      {
        works.map((work, index) => (
          <div
            class="timeline-item group relative flex h-[35vh] w-[70vw] max-w-lg flex-none origin-center flex-col items-center justify-center"
            data-index={index}
          >
            <div class="image-wrapper relative h-full w-full overflow-hidden transition-transform duration-100 ease-out">
              <Image
                src={work.image}
                alt={work.title}
                class="h-full w-full object-cover filter transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]"
              />
            </div>
            
            <div class="pointer-events-none absolute left-0 top-full mt-6 flex w-full justify-between md:mt-8">
              <div class="info-left text-left transition-all duration-500 ease-[cubic-bezier(0.19,1,0.22,1)]" style="opacity: 0; transform: translate3d(0, 20px, 0);">
                <h3 class="text-xl font-bold tracking-tight uppercase md:text-2xl">
                  {work.title}
                </h3>
                {work.subtitle && <div class="mt-1 text-sm text-foreground/80">{work.subtitle}</div>}
              </div>
              <div class="info-right text-right transition-all duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] delay-75" style="opacity: 0; transform: translate3d(0, 20px, 0);">
                {work.role && (
                  <p class="pt-1 text-xs tracking-widest text-muted-foreground uppercase">
                    {work.role}
                  </p>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Ticks & fixed center marker -->
    <div
      class="pointer-events-none absolute bottom-8 left-0 z-20 w-full md:bottom-12"
    >
      <!-- Fixed center marker -->
      <div
        class="absolute bottom-0 left-1/2 h-16 w-px -translate-x-1/2 bg-foreground shadow-[0_0_10px_rgba(255,255,255,0.5)]"
      >
      </div>

      <!-- Ticks container -->
      <div class="relative h-4 w-full overflow-hidden opacity-30">
        <div
          id="ticks-container"
          class="absolute top-0 left-0 h-full w-full"
          style="background-image: repeating-linear-gradient(to right, currentColor 0, currentColor 1px, transparent 1px, transparent 1.5vw);"
        >
        </div>
      </div>

      <div
        class="mt-4 text-center font-mono text-xs tracking-[0.4em] uppercase opacity-50"
        id="timeline-year"
      >
        SELECTED WORKS
      </div>
    </div>
  </div>
</div>

<script>
  // ==========================================
  // CONFIGURATION
  // ==========================================
  // Controls how responsive the timeline is while you are actively scrolling (higher = faster start, snappier)
  const SCROLL_EASE_ACTIVE = 0.2
  // Controls the inertia/smoothness when you stop scrolling (lower = longer, floating stop)
  const SCROLL_EASE_REST = 0.2
  // How much you have to physically scroll to move the timeline.
  // 1.0 = normal horizontal swipe distance
  // 1.5 = heavier friction (takes 50% more scrolling to get across)
  const SCROLL_FRICTION = 1.25
  // The size of the image when perfectly centered (1.15 = 115%)
  const FOCUSED_SCALE = 1.15
  // The size of the images that are not perfectly centered (1.0 = 100%)
  const UNFOCUSED_SCALE = 0.85

  // Add a self-executing init block for Astro
  document.addEventListener("DOMContentLoaded", initTimeline)

  // Also run on page load just in case
  initTimeline()

  function initTimeline() {
    const wrapper = document.getElementById(
      "timeline-wrapper"
    ) as HTMLElement | null
    const container = document.getElementById(
      "timeline-container"
    ) as HTMLElement | null
    const items = document.querySelectorAll(".timeline-item")
    const ticks = document.getElementById(
      "ticks-container"
    ) as HTMLElement | null

    if (wrapper && container && items.length > 0) {
      let targetTranslateX = 0
      let currentTranslateX = 0
      let currentEase = SCROLL_EASE_REST
      let isUpdating = false

      function calculateScroll() {
        if (!wrapper || !container) return

        // Dynamically set the height of the wrapper to control how much scrolling is required
        // By multiplying the container's width by our friction variable, we stretch the scroll distance!
        const scrollDistance = container.scrollWidth * SCROLL_FRICTION
        wrapper.style.height = `${scrollDistance}px`

        const rect = wrapper.getBoundingClientRect()
        // rect.top is the position of the sticky wrapper relative to the viewport
        const maxScroll = wrapper.offsetHeight - window.innerHeight
        let scrolled = -rect.top

        if (scrolled < 0) scrolled = 0
        if (scrolled > maxScroll) scrolled = maxScroll

        const progress = scrolled / maxScroll

        // Calculate target translation X based on inner content width vs window width
        const maxTranslateX = container.scrollWidth - window.innerWidth
        targetTranslateX = -maxTranslateX * progress

        // Give it an immediate snappy "kick" by using the active ease factor while the user scrolls
        currentEase = SCROLL_EASE_ACTIVE

        if (!isUpdating) {
          isUpdating = true
          requestAnimationFrame(renderLoop)
        }
      }

      function renderLoop() {
        if (!container) return

        // Relax the ease factor smoothly back down to the resting/floating state
        currentEase += (SCROLL_EASE_REST - currentEase) * 0.08

        // Lerp easing towards the true scroll target using our dynamic inertia
        currentTranslateX +=
          (targetTranslateX - currentTranslateX) * currentEase

        // Stop animation if we are very close to the target to save battery/CPU
        if (
          0.1 > Math.abs(targetTranslateX - currentTranslateX) &&
          0.01 > Math.abs(currentEase - SCROLL_EASE_REST)
        ) {
          currentTranslateX = targetTranslateX
          isUpdating = false
        } else {
          requestAnimationFrame(renderLoop)
        }

        // Apply hardware-accelerated transform
        container.style.transform = `translate3d(${currentTranslateX}px, 0, 0)`

        if (ticks) {
          // Slide the background image to simulate continuous moving ticks
          ticks.style.backgroundPosition = `${currentTranslateX}px 0`
        }

        // Determine which item is at the center
        const windowCenter = window.innerWidth / 2

        items.forEach((item) => {
          const itemRect = (item as HTMLElement).getBoundingClientRect()
          const itemCenterInWorld = itemRect.left + itemRect.width / 2
          const distFromCenter = Math.abs(windowCenter - itemCenterInWorld)

          const activationZone = window.innerWidth * 0.4
          let scale = UNFOCUSED_SCALE

          if (distFromCenter < activationZone) {
            // 0 (center) to 1 (edge)
            const normalizedDist = distFromCenter / activationZone

            // smooth ease-out curve interpolates from UNFOCUSED_SCALE to FOCUSED_SCALE
            const easeOut = 1 - Math.pow(normalizedDist, 2)
            scale =
              UNFOCUSED_SCALE +
              (FOCUSED_SCALE - UNFOCUSED_SCALE) * Math.max(0, easeOut)
          }

          const imageWrapper = item.querySelector(
            ".image-wrapper"
          ) as HTMLElement
          if (imageWrapper) {
            imageWrapper.style.transform = `scale(${scale})`
          }

          const infoLeft = item.querySelector(".info-left") as HTMLElement
          const infoRight = item.querySelector(".info-right") as HTMLElement
          
          if (distFromCenter < window.innerWidth * 0.15) {
            if (infoLeft) {
              infoLeft.style.opacity = "1"
              infoLeft.style.transform = "translate3d(0, 0, 0)"
            }
            if (infoRight) {
              infoRight.style.opacity = "1"
              infoRight.style.transform = "translate3d(0, 0, 0)"
            }
          } else {
            if (infoLeft) {
              infoLeft.style.opacity = "0"
              infoLeft.style.transform = "translate3d(0, 20px, 0)"
            }
            if (infoRight) {
              infoRight.style.opacity = "0"
              infoRight.style.transform = "translate3d(0, 20px, 0)"
            }
          }
        })
      }

      window.addEventListener("scroll", calculateScroll, { passive: true })
      window.addEventListener("resize", calculateScroll)

      // Initial layout setup
      calculateScroll()
      currentTranslateX = targetTranslateX // skip easing on load
      renderLoop()
    }
  }
</script>
