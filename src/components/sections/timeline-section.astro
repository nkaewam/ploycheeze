---
import { works } from "@/data/works"
import { Image } from "astro:assets"
import { MouseScrollIcon } from "@phosphor-icons/react"
import grain from "@/assets/grain.gif"
import { RoleDisplay } from "../role-display"
import { VideoSheet } from "../video-sheet"
---

<style>
  .has-sub-images:hover .main-image {
    /* Keep main image visible to prevent background flashing */
    opacity: 1;
  }

  .sub-images-container {
    pointer-events: none;
  }

  .sub-image {
    opacity: 0;
    transition:
      opacity 0.5s ease-in-out,
      z-index 0s step-end;
  }
</style>

<div
  id="timeline-wrapper"
  class="relative w-full bg-background text-foreground"
  style="min-height: 300vh;"
>
  <div
    class="sticky top-0 flex h-screen w-full flex-col justify-center overflow-hidden"
  >
    <!-- Film Grain Overlay -->
    <div
      class="grain-overlay pointer-events-none absolute inset-0 z-0 scale-110 opacity-[0.05] mix-blend-overlay"
      style={`background-image: url(${grain.src}); background-repeat: repeat;`}
    >
    </div>

    <h2
      class="absolute top-0 left-0 flex items-center px-8 py-8 text-2xl tracking-tight"
    >
      <span class="text-3xl text-transparent select-none">ploycheeze</span>
      <div class="relative top-2">
        <RoleDisplay client:load />
      </div>
    </h2>

    <p class="absolute top-20 left-8 z-30 text-base tracking-tight lowercase">
      Selected Works
    </p>

    <!-- Timeline Container -->
    <div
      id="timeline-container"
      class="z-10 flex h-full w-max items-center gap-28 px-[50vw] will-change-transform"
    >
      {
        works.map((work, index) => (
          <div
            class={`timeline-item group relative flex w-auto flex-none origin-center flex-col items-center justify-center ${work.contentType === "photo" ? "has-sub-images" : "has-video cursor-pointer"}`}
            data-index={index}
            data-type={work.contentType}
            data-vimeo-id={
              work.contentType === "video" ? work.vimeoId : undefined
            }
            style={
              work.contentType === "photo"
                ? `--sub-count: ${work.subImages.length};`
                : ""
            }
          >
            <div class="image-wrapper relative h-auto w-auto overflow-hidden transition-transform duration-100 ease-out">
              <Image
                src={work.image}
                alt={work.title}
                class="main-image max-h-[40vh] w-auto object-contain filter transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]"
              />
              {work.contentType === "photo" && (
                <div class="sub-images-container absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-500 group-hover:opacity-100">
                  {work.subImages.map((subImg, subIdx) => (
                    <Image
                      src={subImg}
                      alt={`${work.title} sub ${subIdx}`}
                      class="sub-image absolute inset-0 h-full w-full object-contain"
                      style={`--sub-index: ${subIdx};`}
                    />
                  ))}
                </div>
              )}
            </div>

            <div
              class="text-container pointer-events-none absolute top-full mt-8 flex justify-between"
              style="width: 100%; left: 0%;"
            >
              <div
                class="info-left text-left transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)]"
                style="opacity: 0; transform: translate3d(0, -20px, 0);"
              >
                <h3 class="text-xl font-normal tracking-tight md:text-2xl">
                  {work.title}
                </h3>
                {work.subtitle && (
                  <div class="mt-1 text-sm text-foreground/80">
                    {work.subtitle}
                  </div>
                )}
              </div>
              <div
                class="info-right text-right transition-all delay-100 duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)]"
                style="opacity: 0; transform: translate3d(0, -20px, 0);"
              >
                {work.role && (
                  <p class="pt-1 text-base text-muted-foreground lowercase">
                    {work.role}
                  </p>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Ticks & dynamic marker -->
    <div
      class="pointer-events-none absolute bottom-0 left-0 z-20 w-full overflow-hidden"
    >
      <!-- Ticks container -->
      <div class="relative h-20 w-full">
        <div
          id="ticks-container"
          class="flex h-full items-end gap-[0.8vw] px-[50vw] will-change-transform"
        >
          {
            Array.from({ length: 800 }).map((_, i) => (
              <div
                class="tick w-px flex-none bg-[#f7add6] transition-all duration-700 ease-out"
                style="height: 13px;"
              />
            ))
          }
        </div>
      </div>

      <div
        class="mt-4 flex items-center justify-center gap-1 pb-8 text-center text-base lowercase opacity-50"
        id="timeline-year"
      >
        scroll <MouseScrollIcon size={24} />
      </div>
    </div>

    <!-- Video Sheet -->
    <VideoSheet client:load />
  </div>
</div>

<script>
  // ==========================================
  // CONFIGURATION
  // ==========================================

  // 1. SCROLL PHYSICS
  const SCROLL_EASE_ACTIVE = 0.2
  const SCROLL_EASE_REST = 0.2
  const SCROLL_FRICTION = 1.25

  // 2. IMAGE SCALING
  const FOCUSED_SCALE = 1.15
  const UNFOCUSED_SCALE = 0.85

  // 3. GROW/SHRINK TICK ANIMATION (Configuration)
  // Animation duration/easing can be adjusted in the "tick" div's class list
  const TICK_GAP_VW = 0.008 // Match gap-[0.6vw]
  const TICK_BASE_HEIGHT = "10px"
  const TICK_ACTIVE_HEIGHT = "35px"
  const TICK_BASE_COLOR = "#f492c1"
  const TICK_ACTIVE_COLOR = "#444444"
  const TICK_GROW_DURATION = "300ms"
  const TICK_SHRINK_DURATION = "700ms"

  // ------------------------------------------

  // Add a self-executing init block for Astro
  document.addEventListener("DOMContentLoaded", initTimeline)

  // Also run on page load just in case
  initTimeline()

  function initTimeline() {
    const wrapper = document.getElementById(
      "timeline-wrapper"
    ) as HTMLElement | null
    const container = document.getElementById(
      "timeline-container"
    ) as HTMLElement | null
    const items = document.querySelectorAll(".timeline-item")
    const ticks = document.getElementById(
      "ticks-container"
    ) as HTMLElement | null

    if (wrapper && container && items.length > 0) {
      let targetTranslateX = 0
      let currentTranslateX = 0
      let currentEase = SCROLL_EASE_REST
      let isUpdating = false

      let lastCenterIdx = -1

      function calculateScroll() {
        if (!wrapper || !container) return

        // Dynamically set the height of the wrapper to control how much scrolling is required
        // By multiplying the container's width by our friction variable, we stretch the scroll distance!
        const scrollDistance = container.scrollWidth * SCROLL_FRICTION
        wrapper.style.height = `${scrollDistance}px`

        const rect = wrapper.getBoundingClientRect()
        // rect.top is the position of the sticky wrapper relative to the viewport
        const maxScroll = wrapper.offsetHeight - window.innerHeight
        let scrolled = -rect.top

        if (scrolled < 0) scrolled = 0
        if (scrolled > maxScroll) scrolled = maxScroll

        const progress = scrolled / maxScroll

        // Calculate target translation X based on inner content width vs window width
        const maxTranslateX = container.scrollWidth - window.innerWidth
        targetTranslateX = -maxTranslateX * progress

        // Give it an immediate snappy "kick" by using the active ease factor while the user scrolls
        currentEase = SCROLL_EASE_ACTIVE

        if (!isUpdating) {
          isUpdating = true
          requestAnimationFrame(renderLoop)
        }
      }

      function renderLoop() {
        if (!container) return

        // Relax the ease factor smoothly back down to the resting/floating state
        currentEase += (SCROLL_EASE_REST - currentEase) * 0.08

        // Lerp easing towards the true scroll target using our dynamic inertia
        currentTranslateX +=
          (targetTranslateX - currentTranslateX) * currentEase

        // Stop animation if we are very close to the target to save battery/CPU
        if (
          0.1 > Math.abs(targetTranslateX - currentTranslateX) &&
          0.01 > Math.abs(currentEase - SCROLL_EASE_REST)
        ) {
          currentTranslateX = targetTranslateX
          isUpdating = false
        } else {
          requestAnimationFrame(renderLoop)
        }

        // Apply hardware-accelerated transform
        container.style.transform = `translate3d(${currentTranslateX}px, 0, 0)`

        if (ticks) {
          const tickGap = window.innerWidth * TICK_GAP_VW
          const tickStepSize = 1 + tickGap

          // Dynamically calculate the ticks offset so the first tick aligns exactly with the left edge of the first image
          let TICK_OFFSET = 0
          const firstItem = items[0] as HTMLElement
          if (firstItem) {
            const distFromCenterToLeftEdge =
              (firstItem.offsetWidth * FOCUSED_SCALE) / 2
            TICK_OFFSET = Math.round(distFromCenterToLeftEdge / tickStepSize)
          }

          ticks.style.transform = `translate3d(${currentTranslateX - TICK_OFFSET * tickStepSize}px, 0, 0)`

          const tickElements = ticks.querySelectorAll(".tick")
          if (tickElements.length > 0) {
            const centerIdx =
              Math.round(-currentTranslateX / tickStepSize) + TICK_OFFSET

            if (centerIdx !== lastCenterIdx) {
              // Reset previous active area
              if (lastCenterIdx >= 0) {
                // We check a slightly wider range to be safe when scrolling fast
                for (let i = lastCenterIdx - 4; i <= lastCenterIdx + 4; i++) {
                  const t = tickElements[i] as HTMLElement
                  if (t && i !== centerIdx) {
                    // Transitions back to base (Shrink) use the explicit shrink duration
                    t.style.transitionDuration = TICK_SHRINK_DURATION
                    t.style.height = TICK_BASE_HEIGHT
                    t.style.backgroundColor = TICK_BASE_COLOR
                  }
                }
              }

              // Set new centermost tick
              const activeTick = tickElements[centerIdx] as HTMLElement
              if (activeTick) {
                // Growth transition duration override
                activeTick.style.transitionDuration = TICK_GROW_DURATION
                activeTick.style.height = TICK_ACTIVE_HEIGHT
                activeTick.style.backgroundColor = TICK_ACTIVE_COLOR
              }

              lastCenterIdx = centerIdx
            }
          }
        }

        // Determine which item is at the center
        const windowCenter = window.innerWidth / 2

        let closestItemIndex = -1

        items.forEach((item, index) => {
          const itemRect = (item as HTMLElement).getBoundingClientRect()
          const itemCenterInWorld = itemRect.left + itemRect.width / 2

          // Information appears for the "next" item as soon as the center tick passes the 3/4 point of the "current" item
          if (
            closestItemIndex === -1 &&
            itemRect.left + itemRect.width * 0.75 >= windowCenter
          ) {
            closestItemIndex = index
          }

          const distFromCenter = Math.abs(windowCenter - itemCenterInWorld)

          const activationZone = window.innerWidth * 0.4
          let scale = UNFOCUSED_SCALE

          if (distFromCenter < activationZone) {
            // 0 (center) to 1 (edge)
            const normalizedDist = distFromCenter / activationZone

            // smooth ease-out curve interpolates from UNFOCUSED_SCALE to FOCUSED_SCALE
            const easeOut = 1 - Math.pow(normalizedDist, 2)
            scale =
              UNFOCUSED_SCALE +
              (FOCUSED_SCALE - UNFOCUSED_SCALE) * Math.max(0, easeOut)
          }

          const imageWrapper = item.querySelector(
            ".image-wrapper"
          ) as HTMLElement
          if (imageWrapper) {
            imageWrapper.style.transform = `scale(${scale})`
          }

          const textContainer = item.querySelector(
            ".text-container"
          ) as HTMLElement
          if (textContainer) {
            textContainer.style.width = `${scale * 100}%`
            textContainer.style.left = `${(1 - scale) * 50}%`
          }
        })

        items.forEach((item, index) => {
          const infoLeft = item.querySelector(".info-left") as HTMLElement
          const infoRight = item.querySelector(".info-right") as HTMLElement

          if (index === closestItemIndex) {
            if (infoLeft) {
              infoLeft.style.opacity = "1"
              infoLeft.style.transform = "translate3d(0, 0, 0)"
            }
            if (infoRight) {
              infoRight.style.opacity = "1"
              infoRight.style.transform = "translate3d(0, 0, 0)"
            }
          } else {
            if (infoLeft) {
              infoLeft.style.opacity = "0"
              infoLeft.style.transform = "translate3d(0, -20px, 0)"
            }
            if (infoRight) {
              infoRight.style.opacity = "0"
              infoRight.style.transform = "translate3d(0, -20px, 0)"
            }
          }
        })
      }

      // ==========================================
      // SUB-IMAGES SLIDESHOW LOGIC
      // ==========================================
      items.forEach((item) => {
        const subImages = item.querySelectorAll(
          ".sub-image"
        ) as NodeListOf<HTMLElement>
        if (subImages.length > 0) {
          let slideTimer: any = null
          let currentIdx = -1

          const showNext = () => {
            currentIdx = (currentIdx + 1) % subImages.length
            subImages.forEach((img, i) => {
              if (i === currentIdx) {
                img.style.opacity = "1"
                img.style.zIndex = "20"
              } else {
                img.style.opacity = "0"
                img.style.zIndex = "1"
              }
            })
          }

          item.addEventListener("mouseenter", () => {
            currentIdx = 0
            subImages.forEach((img, i) => {
              img.style.opacity = i === 0 ? "1" : "0"
              img.style.zIndex = i === 0 ? "20" : "1"
            })
            slideTimer = setInterval(showNext, 1500)
          })

          item.addEventListener("mouseleave", () => {
            if (slideTimer) clearInterval(slideTimer)
            subImages.forEach((img) => {
              img.style.opacity = "0"
            })
            currentIdx = -1
          })
        }
      })

      // ==========================================
      // VIDEO SHEET LOGIC
      // ==========================================
      items.forEach((item) => {
        const type = item.getAttribute("data-type")
        if (type === "video") {
          item.addEventListener("click", () => {
            const vimeoId = item.getAttribute("data-vimeo-id")
            if (vimeoId) {
              const titleEl = item.querySelector("h3")
              const subtitleEl = item.querySelector(".info-left .mt-1.text-sm")
              const roleEl = item.querySelector(".info-right p")

              const event = new CustomEvent("open-video-sheet", {
                detail: {
                  vimeoId,
                  title: titleEl ? titleEl.innerHTML : "",
                  subtitle: subtitleEl ? subtitleEl.innerHTML : "",
                  role: roleEl ? roleEl.innerHTML : "",
                },
              })
              window.dispatchEvent(event)
            }
          })
        }
      })

      window.addEventListener("scroll", calculateScroll, { passive: true })
      window.addEventListener("resize", calculateScroll)

      // Initial layout setup
      calculateScroll()
      currentTranslateX = targetTranslateX // skip easing on load
      renderLoop()
    }
  }
</script>
