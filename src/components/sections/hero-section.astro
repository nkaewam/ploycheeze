<section class="relative h-full w-full text-white/90">
  <video
    src="/hero.webm"
    autoplay
    muted
    loop
    playsinline
    class="pointer-events-none absolute inset-0 h-full w-full object-cover select-none"
  ></video>

  <!-- Video Dim Overlay -->
  <div class="pointer-events-none absolute inset-0 z-10 bg-black/50"></div>

  <!-- Overlay/Content Container (constrained to dynamic viewport height to avoid address bar overlapping content) -->
  <div
    class="relative z-20 flex h-dvh w-full flex-col px-8 text-white mix-blend-difference"
  >
    <!-- Spacer for potential top navigation if needed inside flex -->
    <div class="pointer-events-none h-20 opacity-0 sm:h-24" aria-hidden="true">
    </div>

    <!-- Centered Text Content -->
    <div class="relative -top-5 flex flex-1 items-center justify-center">
      <div class="max-w-4xl text-center">
        <p class="text-3xl font-light tracking-tight">
          A multidisciplinary visual storyteller
        </p>
        <p class="text-3xl font-light tracking-tight">
          working across film, photography, and brand imagery.
        </p>
      </div>
    </div>

    <p
      class="absolute right-0 bottom-2.5 left-0 z-100 flex justify-center font-light lowercase"
    >
      (scroll)
    </p>
  </div>
</section>
