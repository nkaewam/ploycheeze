---
import { Image } from "astro:assets"
import heroBg from "@/assets/hero-bg.png"
---

<section class="relative h-screen w-full overflow-hidden text-white/90">
  <Image
    src={heroBg}
    alt="Hero background"
    class="pointer-events-none absolute inset-0 h-full w-full object-cover select-none"
    priority
    loading="eager"
  />

  <!-- Overlay/Content Container -->
  <div class="relative z-10 flex h-full flex-col px-8 pb-10">
    <!-- Spacer for potential top navigation if needed inside flex -->
    <div class="pointer-events-none h-20 opacity-0 sm:h-24" aria-hidden="true">
    </div>

    <!-- Centered Text Content -->
    <div class="flex flex-1 items-center justify-center text-[#404f57]">
      <div class="max-w-3xl text-center">
        <p class="text-2xl font-light tracking-tight">
          A multidisciplinary visual storyteller
        </p>
        <p class="text-2xl font-light tracking-tight">
          working across film, photography, and brand imagery.
        </p>
      </div>
    </div>
  </div>
</section>
