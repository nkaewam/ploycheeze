---
import Layout from "@/layouts/main.astro"
import Navigation from "@/components/navigation.astro"
import HeroSection from "@/components/sections/hero-section.astro"
import StandardSkinSection from "@/components/sections/standard-skin-section.astro"
import TimelineSection from "@/components/sections/timeline-section.astro"
import CatalogSection from "@/components/sections/catalog-section.astro"
// import CatalogSection from "@/components/sections/catalog-section.astro"
---

<Layout>
  <Navigation />

  <div class="sticky top-0 -z-10 h-screen w-full">
    <HeroSection />
  </div>

  <div class="relative z-10 bg-background shadow-2xl">
    <TimelineSection />
  </div>
</Layout>
